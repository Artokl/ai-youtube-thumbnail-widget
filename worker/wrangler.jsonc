{
	"$schema": "node_modules/wrangler/config-schema.json",
	"account_id": "bc34af2e3d4f7bf89df3620170103341",
	"name": "oc-thumbnail-worker",
	"main": "src/index.js",
	"compatibility_date": "2026-03-09",
	"observability": {
		"enabled": true
	},
	"compatibility_flags": [
		"nodejs_compat"
	],
	"vars": {
		"FAL_MODEL": "fal-ai/bytedance/seedream/v4.5/edit",
		"FAL_LLM_PATH": "openrouter/router/openai/v1/chat/completions",
		"FAL_LLM_MODEL": "meta-llama/llama-3.1-8b-instruct"
    }
